generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Profile {
  id             String    @id @default(uuid())
  username       String    @unique
  email          String    @unique
  password_hash  String?
  role           String    @default("user")
  avatar_url     String?
  created_at     DateTime  @default(now())
  updated_at     DateTime  @default(now())

  flashcards     Flashcard[]
  study_materials StudyMaterial[]
  reviews        ReviewSession[]
  exams          ExamSession[]
  analytics      Analytics?
  blog_posts     BlogPost[]
}

model StudyMaterial {
  id         String   @id @default(uuid())
  user_id    String
  title      String
  file_url   String
  file_type  String
  status     String   @default("pending")
  created_at DateTime @default(now())

  user      Profile     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  flashcards Flashcard[]
}

model Flashcard {
  id           String   @id @default(uuid())
  material_id  String?
  user_id      String
  question     String
  answer       String
  difficulty   Int      @default(0)
  next_review  DateTime?
  interval_days Int     @default(1)
  ease_factor  Float    @default(2.5)
  created_at   DateTime @default(now())

  user     Profile           @relation(fields: [user_id], references: [id], onDelete: Cascade)
  material StudyMaterial?    @relation(fields: [material_id], references: [id], onDelete: Cascade)
  sessions ReviewSession[]
}

model ReviewSession {
  id          String   @id @default(uuid())
  user_id     String
  flashcard_id String
  rating      Int
  reviewed_at DateTime @default(now())

  user     Profile    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  flashcard Flashcard @relation(fields: [flashcard_id], references: [id], onDelete: Cascade)
}

model ExamSession {
  id              String   @id @default(uuid())
  user_id         String
  title           String
  score           Float?
  total_questions Int?
  duration_seconds Int?
  completed_at    DateTime @default(now())

  user Profile @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model Analytics {
  id             String   @id @default(uuid())
  user_id        String   @unique
  retention_score Float   @default(0)
  mastery_score   Float   @default(0)
  streak_days     Int      @default(0)
  last_review     DateTime?
  total_reviews   Int      @default(0)
  created_at      DateTime @default(now())
  updated_at      DateTime @default(now())

  user Profile @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model BlogPost {
  id           String   @id @default(uuid())
  title        String
  slug         String   @unique
  content      String
  excerpt      String?
  category     String
  author_id    String
  cover_image  String?
  published_at DateTime @default(now())
  created_at   DateTime @default(now())

  author Profile @relation(fields: [author_id], references: [id])
}
